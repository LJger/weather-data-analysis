<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.example.backend.mapper.WeatherStationMapper">

    <resultMap id="weatherStationResultMap" type="com.example.backend.entity.WeatherStation">
        <id property="stationId"              column="station_id"/>
        <result property="province"           column="province"/>
        <result property="stationName"        column="station_name"/>
        <result property="latitude"           column="latitude"/>
        <result property="longitude"          column="longitude"/>
        <result property="pressureSensorAltitude" column="pressure_sensor_altitude"/>
        <result property="observationAltitude"    column="observation_altitude"/>
    </resultMap>

    <select id="findById" resultMap="weatherStationResultMap">
        SELECT * FROM gra_project.weather_stations WHERE station_id = #{stationId}
    </select>

    <select id="findAll" resultMap="weatherStationResultMap">
        SELECT * FROM gra_project.weather_stations
    </select>

    <select id="findAllByIds" resultMap="weatherStationResultMap">
        SELECT * FROM gra_project.weather_stations
        WHERE station_id IN
        <foreach item="id" collection="stationIds" open="(" separator="," close=")">
            #{id}
        </foreach>
    </select>

    <select id="findDistinctProvinces" resultType="string">
        SELECT DISTINCT province FROM gra_project.weather_stations ORDER BY province ASC
    </select>

    <select id="findByProvinceOrderByStationNameAsc" resultMap="weatherStationResultMap">
        SELECT * FROM gra_project.weather_stations
        WHERE province = #{province}
        ORDER BY station_name ASC
    </select>

</mapper>
